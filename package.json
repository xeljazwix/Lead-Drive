  "description": "Secure standalone cloud file storage backend with ClamAV AV and WORM ransomware protection",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "setup-admin": "node scripts/setup-admin.js",
    "db:init": "node scripts/db-init.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "node scripts/db-init.js",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "archiver": "^8.0.0",
    "basic-ftp": "^5.0.5",
    "bcryptjs": "^2.4.3",
    "clamscan": "^2.1.2",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "generic-pool": "^3.9.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "nanoid": "^5.0.7",
    "prisma": "^5.22.0",
    "sharp": "^0.35.1",
    "socket.io": "^4.8.3",
    "ssh2-sftp-client": "^12.1.1",
    "unzipper": "^0.12.3",
