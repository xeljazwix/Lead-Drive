# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://clouduser:cloudpassword@localhost:5432/clouddrivedb"

# ─── ClamAV ──────────────────────────────────────────────────────────────────
# Set to false when developing locally without Docker (uploads will warn but succeed).
# Must be true (or omitted) in production — never skip AV scanning in prod.
CLAMAV_ENABLED=false
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# ─── Storage Paths ───────────────────────────────────────────────────────────
TEMP_DIR=./temp
STORAGE_DIR=./storage

# ─── Admin Bootstrap (optional) ──────────────────────────────────────────────
# If not set, a random password will be generated and printed to stdout.
INITIAL_ADMIN_USERNAME=superadmin
# INITIAL_ADMIN_PASSWORD=
